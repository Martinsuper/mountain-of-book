---
// src/pages/archive.astro
import { getCollection } from 'astro:content';
import { sortPostsByDate, groupPostsByYear } from '../lib/post-utils';
import BaseLayout from '../layouts/BaseLayout.astro';

const posts = await getCollection('posts', ({ data }) => !data.draft);
sortPostsByDate(posts);

// 按年份分组
const yearGroups = groupPostsByYear(posts);
const years = Array.from(yearGroups.keys()).sort((a, b) => b - a);
---

<BaseLayout title="归档">
  <h1 class="text-3xl font-bold mb-8">归档</h1>

  <p class="text-gray-500 dark:text-gray-400 mb-8">
    共 {posts.length} 篇文章
  </p>

  {years.map((year) => (
    <section class="mb-10">
      <h2 class="text-2xl font-bold mb-4 text-gray-700 dark:text-gray-300">
        {year} 年
        <span class="text-sm text-gray-500 ml-2">{yearGroups.get(year)?.length || 0} 篇</span>
      </h2>
      <ul class="space-y-4">
        {yearGroups.get(year)?.map((post) => (
          <li class="flex items-start gap-4">
            <time class="text-sm text-gray-500 dark:text-gray-400 whitespace-nowrap">
              {post.data.date.toLocaleDateString('zh-CN', {
                month: '2-digit',
                day: '2-digit'
              })}
            </time>
            <div>
              <a
                href={`/posts/${post.id}/`}
                class="hover:text-blue-600 dark:hover:text-blue-400 font-medium"
              >
                {post.data.title}
              </a>
              {post.data.tags && (
                <div class="flex gap-2 mt-1">
                  {post.data.tags.map((tag) => (
                    <a
                      href={`/tags/${tag}/`}
                      class="text-xs text-gray-500 hover:text-blue-600 dark:hover:text-blue-400"
                    >
                      #{tag}
                    </a>
                  ))}
                </div>
              )}
            </div>
          </li>
        ))}
      </ul>
    </section>
  ))}
</BaseLayout>