---
// src/pages/archive.astro
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const posts = await getCollection('posts', ({ data }) => !data.draft);
posts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

// 按年份分组
const archive: Record<string, { year: number; posts: any[] }> = {};
posts.forEach((post) => {
  const year = post.data.date.getFullYear();
  if (!archive[year]) {
    archive[year] = { year, posts: [] };
  }
  archive[year].posts.push(post);
});

// 按年份降序排列
const years = Object.values(archive).sort((a, b) => b.year - a.year);
---

<BaseLayout title="归档">
  <h1 class="text-3xl font-bold mb-8">归档</h1>

  <p class="text-gray-500 dark:text-gray-400 mb-8">
    共 {posts.length} 篇文章
  </p>

  {years.map((group) => (
    <section class="mb-10">
      <h2 class="text-2xl font-bold mb-4 text-gray-700 dark:text-gray-300">
        {group.year} 年
        <span class="text-sm text-gray-500 ml-2">{group.posts.length} 篇</span>
      </h2>
      <ul class="space-y-4">
        {group.posts.map((post) => (
          <li class="flex items-start gap-4">
            <time class="text-sm text-gray-500 dark:text-gray-400 whitespace-nowrap">
              {post.data.date.toLocaleDateString('zh-CN', {
                month: '2-digit',
                day: '2-digit'
              })}
            </time>
            <div>
              <a
                href={`/posts/${post.id}/`}
                class="hover:text-blue-600 dark:hover:text-blue-400 font-medium"
              >
                {post.data.title}
              </a>
              {post.data.tags && (
                <div class="flex gap-2 mt-1">
                  {post.data.tags.map((tag) => (
                    <a
                      href={`/tags/${tag}/`}
                      class="text-xs text-gray-500 hover:text-blue-600 dark:hover:text-blue-400"
                    >
                      #{tag}
                    </a>
                  ))}
                </div>
              )}
            </div>
          </li>
        ))}
      </ul>
    </section>
  ))}
</BaseLayout>