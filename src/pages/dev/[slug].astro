---
// 开发预览页面 - 动态路由，每篇文章独立页面
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

// 生成静态路径
export async function getStaticPaths() {
  const posts = await getCollection('posts');
  posts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post, allPosts: posts }
  }));
}

interface Props {
  post: any;
  allPosts: any[];
}

const { post, allPosts } = Astro.props;
const { Content } = await post.render();
---

<BaseLayout title={`预览: ${post.data.title}`}>
  <div class="flex gap-6" style="min-height: calc(100vh - 120px);">
    <!-- 左侧：文章列表 -->
    <aside class="w-64 shrink-0 border-r border-gray-200 overflow-y-auto">
      <div class="sticky top-0 bg-white pb-2 pt-2 z-10">
        <!-- 新建文章 -->
        <div class="mb-4 px-2">
          <form id="new-post-form" class="flex gap-2">
            <input
              type="text"
              name="title"
              placeholder="输入文章标题..."
              class="flex-1 px-2 py-1 text-sm border border-gray-200 rounded focus:outline-none focus:border-blue-400"
              required
            />
            <button
              type="submit"
              class="px-3 py-1 text-sm bg-blue-500 text-white rounded hover:bg-blue-600 whitespace-nowrap"
            >
              新建
            </button>
          </form>
        </div>
        <h2 class="text-sm font-semibold text-gray-500 mb-2 px-2">文章列表 ({allPosts.length})</h2>
      </div>
      <ul class="space-y-1">
        {allPosts.map((p) => (
          <li>
            <a
              href={`/dev/${p.id}/`}
              class={`block px-3 py-2 rounded text-sm transition-colors ${
                post.id === p.id
                  ? 'bg-blue-100 text-blue-700 font-medium'
                  : 'hover:bg-gray-100 text-gray-700'
              }`}
            >
              <span class="flex items-center gap-2">
                {p.data.draft && (
                  <span class="text-xs bg-yellow-100 text-yellow-700 px-1 rounded">草稿</span>
                )}
                <span class="truncate">{p.data.title}</span>
              </span>
              <span class="text-xs text-gray-400 mt-1 block">
                {p.data.date.toLocaleDateString('zh-CN')}
              </span>
            </a>
          </li>
        ))}
      </ul>
    </aside>

    <!-- 右侧：预览区域 -->
    <main class="flex-1 min-w-0">
      <div>
        <!-- 文件信息栏 -->
        <div class="bg-gray-50 border border-gray-200 rounded p-3 mb-4">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-sm font-medium text-gray-700">{post.data.title}</p>
              <p class="text-xs text-gray-500 mt-1">
                文件路径：<code class="bg-gray-200 px-1 rounded">src/content/posts/{post.id}.md</code>
              </p>
            </div>
            <div class="flex gap-2">
              <a
                href={`/posts/${post.id}/`}
                class="text-xs bg-blue-500 text-white px-3 py-1 rounded hover:bg-blue-600"
                target="_blank"
              >
                查看正式页面
              </a>
              <span class="text-xs text-gray-400">
                {post.data.date.toLocaleDateString('zh-CN')}
              </span>
            </div>
          </div>
          {post.data.tags && (
            <div class="flex gap-1 mt-2">
              {post.data.tags.map((tag: string) => (
                <span class="text-xs bg-gray-200 px-2 py-1 rounded">#{tag}</span>
              ))}
            </div>
          )}
        </div>

        <!-- 文章预览 -->
        <article class="prose prose-gray max-w-none">
          <h1>{post.data.title}</h1>
          {post.data.description && (
            <p class="text-gray-600 italic">{post.data.description}</p>
          )}
          <div class="mt-6">
            <Content />
          </div>
        </article>
      </div>
    </main>
  </div>

  <!-- 底部快捷操作栏 -->
  <div class="fixed bottom-0 left-0 right-0 bg-white border-t border-gray-200 py-2 px-4">
    <div class="max-w-4xl mx-auto flex items-center justify-between text-sm">
      <div class="text-gray-500">
        <span class="mr-4">💡 提示：编辑 Markdown 文件后自动刷新预览</span>
        <span class="text-xs">开发模式</span>
      </div>
      <div class="flex gap-4">
        <a href="/" class="text-blue-500 hover:underline">返回首页</a>
        <a href="/tags/" class="text-gray-500 hover:underline">所有标签</a>
      </div>
    </div>
  </div>

  <!-- 新建文章脚本 -->
  <script>
    document.getElementById('new-post-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const form = e.target as HTMLFormElement;
      const title = (form.querySelector('input[name="title"]') as HTMLInputElement).value.trim();

      if (!title) return;

      const button = form.querySelector('button') as HTMLButtonElement;
      button.textContent = '创建中...';
      button.disabled = true;

      try {
        const res = await fetch('/api/create-post', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ title })
        });

        const data = await res.json();

        if (data.success) {
          // 跳转到入口页，让 Astro 重新加载内容集合
          window.location.href = `/dev/?created=${encodeURIComponent(title)}`;
        } else {
          alert('创建失败: ' + data.error);
          button.textContent = '新建';
          button.disabled = false;
        }
      } catch (err) {
        alert('请求失败，请确保开发服务器正在运行');
        button.textContent = '新建';
        button.disabled = false;
      }
    });
  </script>
</BaseLayout>