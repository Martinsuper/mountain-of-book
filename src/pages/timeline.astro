---
// src/pages/timeline.astro
import { getCollection } from 'astro:content';
import { sortPostsByCreateTime } from '../lib/post-utils';
import BaseLayout from '../layouts/BaseLayout.astro';

const posts = await getCollection('posts', ({ data }) => !data.draft);
sortPostsByCreateTime(posts);

// 格式化日期显示
function formatDate(date: Date): string {
  return date.toLocaleDateString('zh-CN', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  });
}
---

<BaseLayout title="时间轴">
  <h1 class="text-3xl font-bold mb-8">时间轴</h1>

  <p class="text-gray-500 dark:text-gray-400 mb-12">
    共 {posts.length} 篇文章
  </p>

  <div class="relative">
    <!-- 时间轴线 -->
    <div class="absolute left-4 top-0 bottom-0 w-0.5 bg-gray-200 dark:bg-gray-700"></div>

    <ul class="space-y-8">
      {posts.map((post, index) => (
        <li class="relative pl-12">
          <!-- 时间轴节点 -->
          <div class="absolute left-2 top-1 w-4 h-4 rounded-full bg-blue-500 border-4 border-white dark:border-gray-900"></div>

          <!-- 文章卡片 -->
          <article class="border border-gray-200 dark:border-gray-800 rounded-lg p-4 hover:border-blue-300 dark:hover:border-blue-600 transition-colors">
            <time class="text-sm text-gray-500 dark:text-gray-400">
              {formatDate(post.data.date)}
            </time>
            <h2 class="text-xl font-semibold mt-2">
              <a
                href={`/posts/${post.id}/`}
                class="hover:text-blue-600 dark:hover:text-blue-400"
              >
                {post.data.title}
              </a>
            </h2>
            {post.data.description && (
              <p class="text-gray-600 dark:text-gray-400 mt-2 text-sm">
                {post.data.description}
              </p>
            )}
            {post.data.tags && (
              <div class="flex gap-2 mt-3">
                {post.data.tags.map((tag) => (
                  <a
                    href={`/tags/${tag}/`}
                    class="text-xs text-gray-500 hover:text-blue-600 dark:hover:text-blue-400"
                  >
                    #{tag}
                  </a>
                ))}
              </div>
            )}
          </article>
        </li>
      ))}
    </ul>
  </div>
</BaseLayout>