---
// src/pages/tools.astro
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="开发者工具" description="常用开发工具集合">
  <div class="tools-page">
    <!-- 页面标题 -->
    <header class="tools-header">
      <h1>🔧 开发者工具箱</h1>
      <p class="tools-subtitle">常用开发工具集合，助力高效开发</p>
    </header>

    <!-- Tab 导航栏 -->
    <nav class="tools-tabs" id="toolsTabs">
      <button class="tab-btn active" data-tab="json">📋 JSON</button>
      <button class="tab-btn" data-tab="timestamp">🕐 时间戳</button>
      <button class="tab-btn" data-tab="diff">🔀 Diff</button>
      <button class="tab-btn" data-tab="url">🔗 URL</button>
      <button class="tab-btn" data-tab="base64">📦 Base64</button>
    </nav>

    <!-- 工具内容区容器 -->
    <div class="tools-content" id="toolsContent">
      <!-- 各工具内容将通过 JS 动态显示 -->
    </div>
  </div>

  <script>
    // 工具面板HTML模板
    const toolPanels = {
      json: `
        <div class="tool-panel active" id="panel-json">
          <div class="tool-section">
            <label class="tool-label">输入 JSON</label>
            <textarea class="tool-input" id="jsonInput" placeholder='{"name": "example", "value": 123}'></textarea>
            <div class="tool-actions">
              <button class="tool-btn tool-btn-primary" data-action="formatJson">格式化</button>
              <button class="tool-btn tool-btn-success" data-action="minifyJson">压缩</button>
              <button class="tool-btn tool-btn-secondary" data-action="copyJson">复制</button>
              <button class="tool-btn tool-btn-danger" data-action="clearJson">清空</button>
              <span class="json-status" id="jsonStatus"></span>
            </div>
          </div>
          <div class="tool-section">
            <label class="tool-label">输出结果</label>
            <textarea class="tool-output" id="jsonOutput" readonly></textarea>
          </div>
        </div>
      `,
      timestamp: `
        <div class="tool-panel" id="panel-timestamp">
          <div class="tool-section">
            <label class="tool-label">时间戳转换</label>
            <div class="timestamp-input-row">
              <input type="text" id="timestampInput" placeholder="输入时间戳或日期">
              <div class="unit-toggle">
                <button class="active" data-unit="s" data-action="setTimestampUnitS">秒</button>
                <button data-unit="ms" data-action="setTimestampUnitMs">毫秒</button>
              </div>
            </div>
            <div class="tool-actions">
              <button class="tool-btn tool-btn-primary" data-action="convertTimestamp">转换</button>
              <button class="tool-btn tool-btn-secondary" data-action="getCurrentTimestamp">当前时间</button>
              <button class="tool-btn tool-btn-secondary" data-action="copyTimestamp">复制结果</button>
            </div>
            <div class="timestamp-results" id="timestampResults"></div>
          </div>
        </div>
      `,
      diff: `
        <div class="tool-panel" id="panel-diff">
          <div class="tool-section">
            <label class="tool-label">文本对比</label>
            <div class="diff-inputs">
              <div class="input-group">
                <label class="tool-label">原始文本</label>
                <div class="diff-editor-container">
                  <div class="diff-overlay" id="diffOverlayLeft"></div>
                  <textarea class="tool-input diff-editor" id="diffInput1" placeholder="输入原始文本"></textarea>
                </div>
              </div>
              <div class="input-group">
                <label class="tool-label">新文本</label>
                <div class="diff-editor-container">
                  <div class="diff-overlay" id="diffOverlayRight"></div>
                  <textarea class="tool-input diff-editor" id="diffInput2" placeholder="输入新文本"></textarea>
                </div>
              </div>
            </div>
            <div class="tool-actions">
              <button class="tool-btn tool-btn-primary" data-action="compareDiff">对比</button>
              <button class="tool-btn tool-btn-secondary" data-action="clearDiff">清空</button>
            </div>
            <div class="diff-stats" id="diffStats"></div>
          </div>
        </div>
      `,
      url: `
        <div class="tool-panel" id="panel-url">
          <div class="tool-section">
            <label class="tool-label">URL 编码/解码</label>
            <textarea class="tool-input" id="urlInput" placeholder="输入需要编码或解码的URL"></textarea>
            <div class="tool-actions">
              <button class="tool-btn tool-btn-primary" data-action="encodeUrl">URL编码</button>
              <button class="tool-btn tool-btn-success" data-action="decodeUrl">URL解码</button>
              <button class="tool-btn tool-btn-secondary" data-action="copyUrl">复制结果</button>
              <button class="tool-btn tool-btn-danger" data-action="clearUrl">清空</button>
            </div>
            <label class="tool-label">输出结果</label>
            <textarea class="tool-output" id="urlOutput" readonly></textarea>
          </div>
        </div>
      `,
      base64: `
        <div class="tool-panel" id="panel-base64">
          <div class="tool-section">
            <label class="tool-label">Base64 编码/解码</label>
            <div class="file-upload-area" id="fileUploadArea">
              <div class="file-upload-icon">📁</div>
              <div class="file-upload-text">点击选择文件或拖拽文件到此处</div>
              <input type="file" id="fileInput" style="display: none">
            </div>
            <div class="file-info" id="fileInfo" style="display: none;">
              <span class="file-name" id="fileName"></span>
              <span class="file-size" id="fileSize"></span>
              <button class="file-remove" data-action="removeFile">×</button>
            </div>
            <textarea class="tool-input" id="base64Input" placeholder="输入文本或Base64字符串"></textarea>
            <div class="tool-actions">
              <button class="tool-btn tool-btn-primary" data-action="encodeBase64">编码</button>
              <button class="tool-btn tool-btn-success" data-action="decodeBase64">解码</button>
              <button class="tool-btn tool-btn-secondary" data-action="copyBase64">复制结果</button>
              <button class="tool-btn tool-btn-danger" data-action="clearBase64">清空</button>
            </div>
            <label class="tool-label">输出结果</label>
            <textarea class="tool-output" id="base64Output" readonly></textarea>
          </div>
        </div>
      `
    };

    // Toast通知函数
    function showToast(message, type = 'success') {
      const existingToast = document.querySelector('.toast');
      if (existingToast) existingToast.remove();

      const toast = document.createElement('div');
      toast.className = 'toast';
      toast.textContent = message;
      toast.style.cssText = `
        position: fixed;
        bottom: 20px;
        left: 50%;
        transform: translateX(-50%);
        background: ${type === 'error' ? '#ef4444' : '#1f2937'};
        color: #fff;
        padding: 1rem 1.5rem;
        border-radius: 12px;
        z-index: 1000;
      `;
      document.body.appendChild(toast);
      setTimeout(() => toast.remove(), 2000);
    }

    // 复制到剪贴板
    async function copyToClipboard(text) {
      if (!text) {
        showToast('无内容可复制', 'error');
        return;
      }
      try {
        await navigator.clipboard.writeText(text);
        showToast('已复制到剪贴板');
      } catch {
        showToast('复制失败', 'error');
      }
    }

    // 当前选中的Tab
    let currentTab = 'json';
    let timestampUnit = 's';

    // 初始化Tab功能
    function initTabs() {
      const tabsContainer = document.getElementById('toolsTabs');
      const contentContainer = document.getElementById('toolsContent');

      // 渲染所有面板
      contentContainer.innerHTML = Object.values(toolPanels).join('');

      // 绑定工具按钮事件
      bindToolActions();

      // 从URL hash获取初始Tab
      const hash = window.location.hash.slice(1);
      if (hash && toolPanels[hash]) {
        currentTab = hash;
      }

      // 设置初始状态
      updateTabState();

      // 绑定Tab点击事件
      const tabButtons = tabsContainer.querySelectorAll('.tab-btn');
      tabButtons.forEach(btn => {
        btn.addEventListener('click', () => {
          const tab = btn.dataset.tab;
          if (tab && tab !== currentTab) {
            currentTab = tab;
            updateTabState();
            // 更新URL hash
            window.location.hash = tab;
          }
        });
      });

      // 监听hash变化
      window.addEventListener('hashchange', () => {
        const hash = window.location.hash.slice(1);
        if (hash && hash !== currentTab && toolPanels[hash]) {
          currentTab = hash;
          updateTabState();
        }
      });

      // 键盘导航支持
      document.addEventListener('keydown', (e) => {
        if (e.target.classList.contains('tab-btn')) {
          const tabs = Array.from(tabsContainer.querySelectorAll('.tab-btn'));
          const currentIndex = tabs.findIndex(t => t === e.target);

          if (e.key === 'ArrowRight' && currentIndex < tabs.length - 1) {
            tabs[currentIndex + 1].focus();
          } else if (e.key === 'ArrowLeft' && currentIndex > 0) {
            tabs[currentIndex - 1].focus();
          } else if (e.key === 'Enter' || e.key === ' ') {
            e.target.click();
          }
        }
      });
    }

    // 绑定所有工具按钮的事件处理器
    function bindToolActions() {
      // 查找所有带有 data-action 属性的按钮
      document.querySelectorAll('[data-action]').forEach(el => {
        const action = el.dataset.action;
        if (actionHandlers[action]) {
          el.addEventListener('click', actionHandlers[action]);
        }
      });

      // 文件上传区域点击
      const fileUploadArea = document.getElementById('fileUploadArea');
      if (fileUploadArea) {
        fileUploadArea.addEventListener('click', () => {
          document.getElementById('fileInput').click();
        });
      }

      // 文件选择
      const fileInput = document.getElementById('fileInput');
      if (fileInput) {
        fileInput.addEventListener('change', handleFileSelect);
      }
    }

    // 事件处理器映射
    const actionHandlers = {
      formatJson: formatJson,
      minifyJson: minifyJson,
      copyJson: copyJson,
      clearJson: clearJson,
      setTimestampUnitS: () => setTimestampUnit('s'),
      setTimestampUnitMs: () => setTimestampUnit('ms'),
      convertTimestamp: convertTimestamp,
      getCurrentTimestamp: getCurrentTimestamp,
      copyTimestamp: copyTimestamp,
      compareDiff: compareDiff,
      clearDiff: clearDiff,
      encodeUrl: encodeUrl,
      decodeUrl: decodeUrl,
      copyUrl: copyUrl,
      clearUrl: clearUrl,
      removeFile: removeFile,
      encodeBase64: encodeBase64,
      decodeBase64: decodeBase64,
      copyBase64: copyBase64,
      clearBase64: clearBase64,
    };

    // 更新Tab状态
    function updateTabState() {
      const tabButtons = document.querySelectorAll('.tab-btn');
      const panels = document.querySelectorAll('.tool-panel');

      tabButtons.forEach(btn => {
        if (btn.dataset.tab === currentTab) {
          btn.classList.add('active');
          btn.setAttribute('aria-selected', 'true');
        } else {
          btn.classList.remove('active');
          btn.setAttribute('aria-selected', 'false');
        }
      });

      panels.forEach(panel => {
        if (panel.id === `panel-${currentTab}`) {
          panel.classList.add('active');
        } else {
          panel.classList.remove('active');
        }
      });
    }

    // JSON工具函数
    function formatJson() {
      const input = document.getElementById('jsonInput').value;
      const output = document.getElementById('jsonOutput');
      const status = document.getElementById('jsonStatus');

      try {
        const parsed = JSON.parse(input);
        output.value = JSON.stringify(parsed, null, 2);
        status.textContent = '✓ 有效JSON';
        status.className = 'json-status valid';
        showToast('格式化成功');
      } catch (e) {
        output.value = '错误: ' + e.message;
        status.textContent = '✗ 无效JSON';
        status.className = 'json-status invalid';
        showToast('JSON格式错误', 'error');
      }
    }

    function minifyJson() {
      const input = document.getElementById('jsonInput').value;
      const output = document.getElementById('jsonOutput');
      const status = document.getElementById('jsonStatus');

      try {
        const parsed = JSON.parse(input);
        output.value = JSON.stringify(parsed);
        status.textContent = '✓ 有效JSON';
        status.className = 'json-status valid';
        showToast('压缩成功');
      } catch (e) {
        output.value = '错误: ' + e.message;
        status.textContent = '✗ 无效JSON';
        status.className = 'json-status invalid';
        showToast('JSON格式错误', 'error');
      }
    }

    function copyJson() {
      const output = document.getElementById('jsonOutput');
      copyToClipboard(output.value);
    }

    function clearJson() {
      document.getElementById('jsonInput').value = '';
      document.getElementById('jsonOutput').value = '';
      document.getElementById('jsonStatus').textContent = '';
    }

    // 时间戳工具函数
    function setTimestampUnit(unit) {
      timestampUnit = unit;
      document.querySelectorAll('.unit-toggle button').forEach(btn => {
        btn.classList.toggle('active', btn.dataset.unit === unit);
      });
    }

    function convertTimestamp() {
      const input = document.getElementById('timestampInput').value.trim();
      const results = document.getElementById('timestampResults');

      if (!input) {
        results.innerHTML = '<p style="color: #ef4444;">请输入时间戳或日期</p>';
        return;
      }

      let timestamp;
      // 判断输入是时间戳还是日期字符串
      if (/^\d+$/.test(input)) {
        timestamp = parseInt(input);
        if (timestampUnit === 's' && timestamp < 10000000000) {
          timestamp *= 1000;
        }
      } else {
        timestamp = new Date(input).getTime();
      }

      if (isNaN(timestamp)) {
        results.innerHTML = '<p style="color: #ef4444;">无效的输入</p>';
        return;
      }

      const date = new Date(timestamp);
      results.innerHTML = `
        <div class="timestamp-result-item">
          <span class="label">时间戳（秒）</span>
          <span class="value">${Math.floor(timestamp / 1000)}</span>
        </div>
        <div class="timestamp-result-item">
          <span class="label">时间戳（毫秒）</span>
          <span class="value">${timestamp}</span>
        </div>
        <div class="timestamp-result-item">
          <span class="label">UTC 时间</span>
          <span class="value">${date.toUTCString()}</span>
        </div>
        <div class="timestamp-result-item">
          <span class="label">本地时间</span>
          <span class="value">${date.toLocaleString('zh-CN')}</span>
        </div>
        <div class="timestamp-result-item">
          <span class="label">ISO 字符串</span>
          <span class="value">${date.toISOString()}</span>
        </div>
      `;
    }

    function getCurrentTimestamp() {
      const now = Date.now();
      const results = document.getElementById('timestampResults');
      const date = new Date(now);
      results.innerHTML = `
        <div class="timestamp-result-item">
          <span class="label">时间戳（秒）</span>
          <span class="value">${Math.floor(now / 1000)}</span>
        </div>
        <div class="timestamp-result-item">
          <span class="label">时间戳（毫秒）</span>
          <span class="value">${now}</span>
        </div>
        <div class="timestamp-result-item">
          <span class="label">UTC 时间</span>
          <span class="value">${date.toUTCString()}</span>
        </div>
        <div class="timestamp-result-item">
          <span class="label">本地时间</span>
          <span class="value">${date.toLocaleString('zh-CN')}</span>
        </div>
        <div class="timestamp-result-item">
          <span class="label">ISO 字符串</span>
          <span class="value">${date.toISOString()}</span>
        </div>
      `;
    }

    function copyTimestamp() {
      const results = document.getElementById('timestampResults');
      const text = results.textContent;
      copyToClipboard(text);
    }

    // Diff工具函数
    function compareDiff() {
      const input1 = document.getElementById('diffInput1');
      const input2 = document.getElementById('diffInput2');
      const overlayLeft = document.getElementById('diffOverlayLeft');
      const overlayRight = document.getElementById('diffOverlayRight');
      const stats = document.getElementById('diffStats');

      const text1 = input1.value;
      const text2 = input2.value;

      if (!text1 && !text2) {
        showToast('请输入文本内容', 'error');
        return;
      }

      const lines1 = text1.split('\n');
      const lines2 = text2.split('\n');

      let added = 0;
      let removed = 0;
      let changed = 0;

      const maxLen = Math.max(lines1.length, lines2.length);
      let leftHtml = '';
      let rightHtml = '';

      for (let i = 0; i < maxLen; i++) {
        const line1 = lines1[i] !== undefined ? lines1[i] : '';
        const line2 = lines2[i] !== undefined ? lines2[i] : '';

        if (line1 === line2) {
          // 完全相同的行
          leftHtml += `<div class="diff-line-overlay same">${escapeHtml(line1) || '&nbsp;'}</div>`;
          rightHtml += `<div class="diff-line-overlay same">${escapeHtml(line2) || '&nbsp;'}</div>`;
        } else if (line1 && !line2) {
          // 删除行：左边有，右边没有
          leftHtml += `<div class="diff-line-overlay removed"><span class="char-diff removed">${escapeHtml(line1)}</span></div>`;
          rightHtml += `<div class="diff-line-overlay empty">&nbsp;</div>`;
          removed++;
        } else if (!line1 && line2) {
          // 新增行：左边没有，右边有
          leftHtml += `<div class="diff-line-overlay empty">&nbsp;</div>`;
          rightHtml += `<div class="diff-line-overlay added"><span class="char-diff added">${escapeHtml(line2)}</span></div>`;
          added++;
        } else {
          // 修改行：字符级别对比
          const charDiff = computeCharDiff(line1, line2);
          leftHtml += `<div class="diff-line-overlay modified">${charDiff.left || '&nbsp;'}</div>`;
          rightHtml += `<div class="diff-line-overlay modified">${charDiff.right || '&nbsp;'}</div>`;
          changed++;
        }
      }

      stats.innerHTML = `
        <span class="diff-stat added">+${added} 新增</span>
        <span class="diff-stat removed">-${removed} 删除</span>
        <span class="diff-stat changed">~${changed} 修改</span>
      `;

      // 显示 overlay 高亮层
      overlayLeft.innerHTML = leftHtml;
      overlayRight.innerHTML = rightHtml;
      overlayLeft.classList.add('active');
      overlayRight.classList.add('active');

      // 让 textarea 透明，显示 overlay
      input1.classList.add('diff-mode');
      input2.classList.add('diff-mode');

      showToast('对比完成');
    }

    // 字符级别差异计算（使用 LCS 算法）
    function computeCharDiff(str1, str2) {
      const chars1 = [...str1];
      const chars2 = [...str2];

      // 计算 LCS
      const lcs = computeLCS(chars1, chars2);

      // 标记差异
      let leftResult = '';
      let rightResult = '';

      let i1 = 0, i2 = 0, lcsIdx = 0;

      // 处理左边字符串
      while (i1 < chars1.length || lcsIdx < lcs.length) {
        if (lcsIdx < lcs.length && i1 < chars1.length && chars1[i1] === lcs[lcsIdx]) {
          leftResult += escapeHtml(chars1[i1]);
          i1++;
          lcsIdx++;
        } else if (i1 < chars1.length) {
          leftResult += `<span class="char-diff removed">${escapeHtml(chars1[i1])}</span>`;
          i1++;
        }
      }

      // 重置 LCS 索引，处理右边字符串
      lcsIdx = 0;
      while (i2 < chars2.length || lcsIdx < lcs.length) {
        if (lcsIdx < lcs.length && i2 < chars2.length && chars2[i2] === lcs[lcsIdx]) {
          rightResult += escapeHtml(chars2[i2]);
          i2++;
          lcsIdx++;
        } else if (i2 < chars2.length) {
          rightResult += `<span class="char-diff added">${escapeHtml(chars2[i2])}</span>`;
          i2++;
        }
      }

      return { left: leftResult, right: rightResult };
    }

    // LCS（最长公共子序列）算法
    function computeLCS(arr1, arr2) {
      const m = arr1.length;
      const n = arr2.length;

      // 构建 DP 表
      const dp = Array(m + 1).fill(null).map(() => Array(n + 1).fill(0));

      for (let i = 1; i <= m; i++) {
        for (let j = 1; j <= n; j++) {
          if (arr1[i - 1] === arr2[j - 1]) {
            dp[i][j] = dp[i - 1][j - 1] + 1;
          } else {
            dp[i][j] = Math.max(dp[i - 1][j], dp[i][j - 1]);
          }
        }
      }

      // 回溯提取 LCS
      const lcs = [];
      let i = m, j = n;
      while (i > 0 && j > 0) {
        if (arr1[i - 1] === arr2[j - 1]) {
          lcs.unshift(arr1[i - 1]);
          i--;
          j--;
        } else if (dp[i - 1][j] > dp[i][j - 1]) {
          i--;
        } else {
          j--;
        }
      }

      return lcs;
    }

    function escapeHtml(text) {
      const div = document.createElement('div');
      div.textContent = text;
      return div.innerHTML;
    }

    function clearDiff() {
      const input1 = document.getElementById('diffInput1');
      const input2 = document.getElementById('diffInput2');
      const overlayLeft = document.getElementById('diffOverlayLeft');
      const overlayRight = document.getElementById('diffOverlayRight');

      input1.value = '';
      input2.value = '';
      input1.classList.remove('diff-mode');
      input2.classList.remove('diff-mode');
      overlayLeft.innerHTML = '';
      overlayRight.innerHTML = '';
      overlayLeft.classList.remove('active');
      overlayRight.classList.remove('active');
      document.getElementById('diffStats').innerHTML = '';
    }

    // URL工具函数
    function encodeUrl() {
      const input = document.getElementById('urlInput').value;
      document.getElementById('urlOutput').value = encodeURIComponent(input);
      showToast('编码成功');
    }

    function decodeUrl() {
      const input = document.getElementById('urlInput').value;
      try {
        document.getElementById('urlOutput').value = decodeURIComponent(input);
        showToast('解码成功');
      } catch (e) {
        document.getElementById('urlOutput').value = '解码错误: ' + e.message;
        showToast('解码失败', 'error');
      }
    }

    function copyUrl() {
      const output = document.getElementById('urlOutput');
      copyToClipboard(output.value);
    }

    function clearUrl() {
      document.getElementById('urlInput').value = '';
      document.getElementById('urlOutput').value = '';
    }

    // Base64工具函数
    let selectedFile = null;

    // Base64编码 (UTF-8 to Base64)
    function encodeBase64Unicode(str) {
      const encoder = new TextEncoder();
      const bytes = encoder.encode(str);
      return btoa(String.fromCharCode(...bytes));
    }

    // Base64解码 (Base64 to UTF-8)
    function decodeBase64Unicode(base64) {
      const binaryStr = atob(base64);
      const bytes = new Uint8Array(binaryStr.length);
      for (let i = 0; i < binaryStr.length; i++) {
        bytes[i] = binaryStr.charCodeAt(i);
      }
      const decoder = new TextDecoder();
      return decoder.decode(bytes);
    }

    function handleFileSelect(event) {
      const file = event.target.files[0];
      if (file) {
        selectedFile = file;
        document.getElementById('fileName').textContent = file.name;
        document.getElementById('fileSize').textContent = formatFileSize(file.size);
        document.getElementById('fileInfo').style.display = 'flex';
      }
    }

    function formatFileSize(bytes) {
      if (bytes < 1024) return bytes + ' B';
      if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(2) + ' KB';
      return (bytes / (1024 * 1024)).toFixed(2) + ' MB';
    }

    function removeFile() {
      selectedFile = null;
      document.getElementById('fileInput').value = '';
      document.getElementById('fileInfo').style.display = 'none';
    }

    function encodeBase64() {
      if (selectedFile) {
        const reader = new FileReader();
        reader.onload = function(e) {
          document.getElementById('base64Output').value = e.target.result;
          showToast('文件编码成功');
        };
        reader.readAsDataURL(selectedFile);
      } else {
        const input = document.getElementById('base64Input').value;
        document.getElementById('base64Output').value = encodeBase64Unicode(input);
        showToast('编码成功');
      }
    }

    function decodeBase64() {
      const input = document.getElementById('base64Input').value;
      try {
        document.getElementById('base64Output').value = decodeBase64Unicode(input);
        showToast('解码成功');
      } catch (e) {
        document.getElementById('base64Output').value = '解码错误: ' + e.message;
        showToast('解码失败', 'error');
      }
    }

    function copyBase64() {
      const output = document.getElementById('base64Output');
      copyToClipboard(output.value);
    }

    function clearBase64() {
      document.getElementById('base64Input').value = '';
      document.getElementById('base64Output').value = '';
      removeFile();
    }

    // 页面加载完成后初始化
    document.addEventListener('DOMContentLoaded', initTabs);
  </script>
</BaseLayout>

