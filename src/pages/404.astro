---
// src/pages/404.astro
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="页面不存在">
  <div class="max-w-md mx-auto py-20 text-center">
    <h1 class="text-6xl font-bold text-gray-300 dark:text-gray-600 mb-4">404</h1>
    <p class="text-xl text-gray-500 dark:text-gray-400 mb-8">
      页面不存在或已被移除
    </p>
    <a
      href="/"
      class="inline-block px-6 py-3 bg-blue-500 text-white rounded-lg hover:bg-blue-600 transition-colors"
    >
      返回首页
    </a>
  </div>
</BaseLayout>