---
// src/components/ReadingCompanion.astro
---

<div class="reading-companion" id="readingCompanion">
  <div class="reading-companion-card">
    <div class="reading-companion-header">
      <span class="reading-companion-title">阅读伙伴</span>
      <button class="reading-companion-toggle" id="readingCompanionToggle" title="收起">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M4 6l4 4 4-4"/>
        </svg>
      </button>
    </div>
    <div class="reading-companion-body" id="readingCompanionBody">
      <div class="reading-companion-sprite-area">
        <img id="readingSprite" class="reading-sprite" src="" alt="" />
        <div class="reading-companion-level-badge" id="readingLevelBadge"></div>
      </div>
      <div class="reading-companion-stats">
        <div class="reading-stat-row">
          <span class="reading-stat-label">经验值</span>
          <div class="reading-xp-bar">
            <div class="reading-xp-fill" id="readingXpFill"></div>
          </div>
        </div>
        <div class="reading-stat-row">
          <span class="reading-stat-label">亲密度</span>
          <span class="reading-stat-value" id="readingIntimacy">0</span>
        </div>
        <div class="reading-stat-row">
          <span class="reading-stat-label">本次获得</span>
          <span class="reading-stat-value" id="readingSessionXp">+0 XP</span>
        </div>
      </div>
      <div class="reading-companion-speech" id="readingSpeech">
        <span id="readingSpeechText">加油读完这篇文章吧！</span>
      </div>
    </div>
  </div>
</div>

<style>
  .reading-companion {
    margin-top: 1rem;
  }

  .reading-companion-card {
    background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
    border-radius: 12px;
    padding: 0.75rem;
    transition: all 0.3s ease;
  }

  .reading-companion-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0;
  }

  .reading-companion-title {
    font-size: 0.8rem;
    color: #aaa;
    font-weight: 600;
  }

  .reading-companion-toggle {
    background: none;
    border: none;
    color: #888;
    cursor: pointer;
    padding: 2px;
    display: flex;
    transition: transform 0.3s ease;
  }

  .reading-companion-toggle.collapsed {
    transform: rotate(180deg);
  }

  .reading-companion-body {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    overflow: hidden;
    transition: max-height 0.3s ease, opacity 0.3s ease;
    max-height: 300px;
    opacity: 1;
  }

  .reading-companion-body.collapsed {
    max-height: 0;
    opacity: 0;
    margin: 0;
    padding: 0;
  }

  .reading-companion-sprite-area {
    position: relative;
    margin: 0.25rem 0;
  }

  .reading-sprite {
    width: 56px;
    height: 56px;
    image-rendering: pixelated;
    animation: readingFloat 3s ease-in-out infinite;
    filter: drop-shadow(0 2px 6px rgba(0, 0, 0, 0.3));
  }

  @keyframes readingFloat {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-5px); }
  }

  .reading-companion-level-badge {
    position: absolute;
    bottom: -2px;
    right: -2px;
    background: #3b82f6;
    color: #fff;
    font-size: 0.6rem;
    font-weight: 700;
    padding: 0 4px;
    border-radius: 6px;
    line-height: 16px;
  }

  .reading-companion-stats {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .reading-stat-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.7rem;
  }

  .reading-stat-label {
    color: #888;
    min-width: 3em;
    text-align: right;
  }

  .reading-stat-value {
    color: #ccc;
    font-weight: 600;
  }

  .reading-xp-bar {
    flex: 1;
    height: 4px;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 2px;
    overflow: hidden;
  }

  .reading-xp-fill {
    height: 100%;
    background: linear-gradient(90deg, #10b981, #3b82f6);
    border-radius: 2px;
    transition: width 0.5s ease;
  }

  .reading-companion-speech {
    background: rgba(255, 255, 255, 0.08);
    border-radius: 8px;
    padding: 0.4rem 0.6rem;
    width: 100%;
    text-align: center;
  }

  #readingSpeechText {
    font-size: 0.7rem;
    color: #bbb;
    line-height: 1.3;
  }

  @media (max-width: 1023px) {
    .reading-companion {
      margin-top: 2rem;
      margin-bottom: 1rem;
    }
    .reading-companion-card {
      display: flex;
      align-items: center;
      gap: 1rem;
      padding: 0.75rem 1rem;
    }
    .reading-companion-header {
      display: none;
    }
    .reading-companion-body {
      flex-direction: row;
      align-items: center;
      gap: 1rem;
      max-height: none;
    }
    .reading-companion-sprite-area {
      margin: 0;
    }
    .reading-sprite {
      width: 48px;
      height: 48px;
    }
    .reading-companion-stats {
      flex: 1;
    }
    .reading-companion-speech {
      display: none;
    }
  }
</style>

<script>
import { ensureCompanion } from '../lib/poke-companion.js';

const COMPANION_KEY = 'poke_companion';

function getCompanion() {
  try { return JSON.parse(localStorage.getItem(COMPANION_KEY)) || null; }
  catch { return null; }
}

function saveCompanion(data) {
  localStorage.setItem(COMPANION_KEY, JSON.stringify(data));
}

const readingSprite = document.getElementById('readingSprite');
const readingLevelBadge = document.getElementById('readingLevelBadge');
const readingXpFill = document.getElementById('readingXpFill');
const readingIntimacy = document.getElementById('readingIntimacy');
const readingSessionXp = document.getElementById('readingSessionXp');
const readingCompanionToggle = document.getElementById('readingCompanionToggle');
const readingCompanionBody = document.getElementById('readingCompanionBody');
const readingCompanion = document.getElementById('readingCompanion');
const readingSpeechText = document.getElementById('readingSpeechText');

let sessionXp = 0;
let lastScrollPercent = 0;
let lastTime = Date.now();

function getLevelThreshold(level) {
  return level * 20 + 10;
}

function updateDisplay() {
  ensureCompanion();
  const companion = getCompanion();
  if (!companion) {
    readingCompanion.style.display = 'none';
    return;
  }

  if (!companion.id || companion.id < 1 || companion.id > 1025) {
    ensureCompanion();
    return updateDisplay();
  }

  readingCompanion.style.display = '';
  readingSprite.src = `https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/${companion.id}.png`;
  readingLevelBadge.textContent = `Lv.${companion.level || 1}`;

  const xpNeeded = getLevelThreshold(companion.level || 1);
  const xpPercent = Math.round(((companion.xp || 0) / xpNeeded) * 100);
  readingXpFill.style.width = `${xpPercent}%`;
  readingIntimacy.textContent = companion.intimacy || 0;
  readingSessionXp.textContent = `+${sessionXp} XP`;
}

function addReadingXp(amount) {
  const companion = getCompanion();
  if (!companion) return;

  companion.xp = (companion.xp || 0) + amount;
  companion.intimacy = (companion.intimacy || 0) + 1;
  sessionXp += amount;

  let leveledUp = false;
  while (companion.xp >= getLevelThreshold(companion.level || 1)) {
    companion.xp -= getLevelThreshold(companion.level || 1);
    companion.level = (companion.level || 1) + 1;
    leveledUp = true;
  }

  saveCompanion(companion);
  updateDisplay();

  if (leveledUp) {
    readingSpeechText.textContent = `升级了！现在是 Lv.${companion.level}！`;
    readingSprite.style.animation = 'none';
    readingSprite.offsetHeight;
    readingSprite.style.animation = 'levelUpSpin 0.8s ease, readingFloat 3s ease-in-out 0.8s infinite';
  }
}

function onScroll() {
  const article = document.querySelector('article');
  if (!article) return;

  const rect = article.getBoundingClientRect();
  const articleHeight = article.scrollHeight;
  const scrollProgress = Math.min(1, (-rect.top + window.innerHeight) / articleHeight);

  if (scrollProgress > lastScrollPercent) {
    const newContent = scrollProgress - lastScrollPercent;
    if (newContent > 0.02) {
      const xpGain = Math.round(newContent * 10);
      if (xpGain > 0) addReadingXp(xpGain);
    }
  }
  lastScrollPercent = scrollProgress;

  const now = Date.now();
  const elapsed = (now - lastTime) / 1000;
  if (elapsed > 30) {
    addReadingXp(1);
    lastTime = now;
  }

  if (scrollProgress >= 0.25 && scrollProgress < 0.3 && lastScrollPercent < 0.25) {
    readingSpeechText.textContent = '已经读了 1/4 了，继续加油！';
  } else if (scrollProgress >= 0.5 && scrollProgress < 0.55 && lastScrollPercent < 0.5) {
    readingSpeechText.textContent = '半程到了！你太棒了！';
  } else if (scrollProgress >= 0.75 && scrollProgress < 0.8 && lastScrollPercent < 0.75) {
    readingSpeechText.textContent = '快读完了，胜利在望！';
  } else if (scrollProgress >= 0.95 && scrollProgress < 1 && lastScrollPercent < 0.95) {
    readingSpeechText.textContent = '恭喜读完！太厉害了！';
  }
}

readingCompanionToggle?.addEventListener('click', () => {
  readingCompanionBody.classList.toggle('collapsed');
  readingCompanionToggle.classList.toggle('collapsed');
});

const styleSheet = document.createElement('style');
styleSheet.textContent = `
  @keyframes levelUpSpin {
    0% { transform: scale(1) rotate(0deg); }
    50% { transform: scale(1.5) rotate(180deg); }
    100% { transform: scale(1) rotate(360deg); }
  }
`;
document.head.appendChild(styleSheet);

ensureCompanion();
updateDisplay();

window.addEventListener('scroll', onScroll, { passive: true });
window.addEventListener('storage', (e) => {
  if (e.key === COMPANION_KEY) updateDisplay();
});
</script>
