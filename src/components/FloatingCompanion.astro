---
// src/components/FloatingCompanion.astro
---

<div class="floating-companion" id="floatingCompanion">
  <div class="floating-companion-inner">
    <div class="floating-sprite-wrapper">
      <div class="floating-shadow"></div>
      <img id="floatingSprite" class="floating-sprite" src="" alt="" />
      <div class="floating-particles" id="floatingParticles"></div>
    </div>
    <div class="floating-speech" id="floatingSpeech">
      <span id="floatingSpeechText"></span>
    </div>
  </div>
</div>

<style>
  .floating-companion {
    position: fixed;
    bottom: 24px;
    left: 24px;
    z-index: 900;
    cursor: grab;
    display: none;
    user-select: none;
  }

  .floating-companion.show {
    display: block;
  }

  .floating-companion.dragging {
    cursor: grabbing;
  }

  .floating-companion.dragging .floating-sprite {
    animation: none;
    transition: none;
  }

  .floating-companion-inner {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 12px;
  }

  .floating-sprite-wrapper {
    position: relative;
    width: 108px;
    height: 108px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .floating-shadow {
    position: absolute;
    bottom: -4px;
    left: 50%;
    transform: translateX(-50%);
    width: 72px;
    height: 14px;
    background: rgba(0, 0, 0, 0.15);
    border-radius: 50%;
    animation: shadowPulse 3s ease-in-out infinite;
  }

  @keyframes shadowPulse {
    0%, 100% { transform: translateX(-50%) scale(1); opacity: 0.3; }
    50% { transform: translateX(-50%) scale(0.8); opacity: 0.2; }
  }

  .floating-sprite {
    width: 108px;
    height: 108px;
    image-rendering: pixelated;
    animation: floatBounce 3s ease-in-out infinite;
    transition: transform 0.2s ease;
    filter: drop-shadow(0 2px 4px rgba(0, 0, 0, 0.2));
  }

  @keyframes floatBounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-8px); }
  }

  .floating-companion:hover .floating-sprite {
    animation: floatExcited 0.3s ease-in-out 3;
  }

  @keyframes floatExcited {
    0%, 100% { transform: translateY(0) scale(1); }
    50% { transform: translateY(-12px) scale(1.15); }
  }

  .floating-speech {
    background: #fff;
    border-radius: 12px;
    padding: 0.5rem 0.75rem;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    position: relative;
    max-width: 200px;
    opacity: 0;
    transform: translateY(5px);
    transition: all 0.3s ease;
    pointer-events: none;
  }

  :global(.dark) .floating-speech {
    background: #1f2937;
    color: #e5e7eb;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
  }

  .floating-speech.show {
    opacity: 1;
    transform: translateY(0);
  }

  .floating-speech::after {
    content: '';
    position: absolute;
    bottom: -6px;
    left: 24px;
    width: 12px;
    height: 12px;
    background: #fff;
    transform: rotate(45deg);
  }

  :global(.dark) .floating-speech::after {
    background: #1f2937;
  }

  #floatingSpeechText {
    font-size: 0.85rem;
    line-height: 1.3;
    color: #374151;
  }

  :global(.dark) #floatingSpeechText {
    color: #d1d5db;
  }

  .floating-particles {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }

  .heart-particle {
    position: absolute;
    font-size: 12px;
    animation: heartFloat 1s ease-out forwards;
  }

  @keyframes heartFloat {
    0% { transform: translateY(0) scale(0.5); opacity: 1; }
    100% { transform: translateY(-30px) scale(1); opacity: 0; }
  }

  .floating-sprite.blink {
    animation: blink 0.15s ease 3;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  .floating-sprite.sleeping {
    animation: sleepBob 2s ease-in-out infinite;
  }

  @keyframes sleepBob {
    0%, 100% { transform: rotate(-3deg) translateY(0); }
    50% { transform: rotate(3deg) translateY(3px); }
  }
</style>

<script>
import { ensureCompanion, getCompanionPokemon, getRandomDialogue } from '../lib/poke-companion.js';
import pokemonData from '../data/pokemon.json';

const COMPANION_KEY = 'poke_companion';

function getCompanion() {
  try { return JSON.parse(localStorage.getItem(COMPANION_KEY)) || null; }
  catch { return null; }
}

function saveCompanion(data) {
  localStorage.setItem(COMPANION_KEY, JSON.stringify(data));
}

function createDefaultCompanion() {
  const pokemon = pokemonData[Math.floor(Math.random() * pokemonData.length)];
  return {
    id: pokemon.id,
    name: pokemon.name,
    nameEn: pokemon.nameEn,
    level: 1,
    xp: 0,
    intimacy: 0,
    mood: 'normal',
    lastFeed: null,
    lastPet: null,
    dialogue: Date.now(),
  };
}

const container = document.getElementById('floatingCompanion');
const sprite = document.getElementById('floatingSprite');
const speech = document.getElementById('floatingSpeech');
const speechText = document.getElementById('floatingSpeechText');
const particles = document.getElementById('floatingParticles');

if (!container || !sprite || !speech || !speechText) {
  console.warn('[FloatingCompanion] Required DOM elements not found');
}

const POSITION_KEY = 'poke_companion_position';

let speechTimeout = null;
let dialogueInterval = null;
let blinkTimeout = null;

// Drag functionality
let isDragging = false;
let origX = 0;
let origY = 0;
let origLeft = 0;
let origBottom = 0;
let hasMoved = false;

function savePosition() {
  try {
    const rect = container.getBoundingClientRect();
    const left = rect.left;
    const bottom = window.innerHeight - rect.bottom;
    localStorage.setItem(POSITION_KEY, JSON.stringify({ left, bottom }));
  } catch { /* ignore */ }
}

function restorePosition() {
  try {
    const pos = JSON.parse(localStorage.getItem(POSITION_KEY));
    if (pos && typeof pos.left === 'number' && typeof pos.bottom === 'number') {
      // Ignore obviously bad positions (from drag bugs)
      if (Math.abs(pos.left) > 10000 || Math.abs(pos.bottom) > 10000) {
        localStorage.removeItem(POSITION_KEY);
        return;
      }
      const vw = window.innerWidth;
      const vh = window.innerHeight;
      // Clamp to viewport, leave at least 30px visible
      const clampedLeft = Math.max(0, Math.min(pos.left, vw - 30));
      const clampedBottom = Math.max(0, Math.min(pos.bottom, vh - 30));
      container.style.left = `${clampedLeft}px`;
      container.style.bottom = `${clampedBottom}px`;
      container.style.right = 'auto';
    }
  } catch { /* ignore */ }
}

function onPointerDown(clientX, clientY) {
  isDragging = true;
  hasMoved = false;
  container.classList.add('dragging');

  const rect = container.getBoundingClientRect();
  origX = clientX;
  origY = clientY;
  origLeft = rect.left;
  origBottom = window.innerHeight - rect.bottom;
}

function onPointerMove(clientX, clientY) {
  if (!isDragging) return;

  const dx = clientX - origX;
  const dy = clientY - origY;

  if (Math.abs(dx) > 3 || Math.abs(dy) > 3) {
    hasMoved = true;
  }

  const rect = container.getBoundingClientRect();
  const vw = window.innerWidth;
  const vh = window.innerHeight;

  let newLeft = origLeft + dx;
  let newBottom = origBottom - dy;

  // Clamp to viewport
  newLeft = Math.max(0, Math.min(newLeft, vw - 20));
  newBottom = Math.max(0, Math.min(newBottom, vh - 20));

  container.style.left = `${newLeft}px`;
  container.style.bottom = `${newBottom}px`;
  container.style.right = 'auto';
}

function onPointerUp() {
  if (isDragging) {
    isDragging = false;
    container.classList.remove('dragging');
    if (hasMoved) savePosition();
  }
}

container.addEventListener('mousedown', (e) => {
  e.preventDefault();
  onPointerDown(e.clientX, e.clientY);
});

document.addEventListener('mousemove', (e) => {
  onPointerMove(e.clientX, e.clientY);
});

document.addEventListener('mouseup', () => {
  onPointerUp();
});

container.addEventListener('touchstart', (e) => {
  const touch = e.touches[0];
  onPointerDown(touch.clientX, touch.clientY);
}, { passive: true });

document.addEventListener('touchmove', (e) => {
  if (!isDragging) return;
  const touch = e.touches[0];
  onPointerMove(touch.clientX, touch.clientY);
}, { passive: true });

document.addEventListener('touchend', () => {
  onPointerUp();
});

function showSpeech(text, duration = 3000) {
  speechText.textContent = text;
  speech.classList.add('show');
  clearTimeout(speechTimeout);
  speechTimeout = setTimeout(() => speech.classList.remove('show'), duration);
}

function createHeartParticle() {
  const heart = document.createElement('span');
  heart.className = 'heart-particle';
  heart.textContent = ['💕', '✨', '💖', '⭐'][Math.floor(Math.random() * 4)];
  heart.style.left = `${20 + Math.random() * 20}px`;
  heart.style.top = `${10 + Math.random() * 10}px`;
  particles.appendChild(heart);
  heart.addEventListener('animationend', () => heart.remove());
}

function triggerBlink() {
  sprite.classList.add('blink');
  setTimeout(() => sprite.classList.remove('blink'), 500);
  blinkTimeout = setTimeout(triggerBlink, 3000 + Math.random() * 8000);
}

function updateSprite(shouldRestorePosition = false) {
  const companion = getCompanion();
  if (!companion) {
    container.classList.remove('show');
    return;
  }

  sprite.src = `https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/${companion.id}.png`;
  sprite.onerror = () => {
    sprite.src = `https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/other/showdown/${companion.id}.gif`;
    sprite.onerror = () => { sprite.style.display = 'none'; };
  };
  sprite.style.display = '';
  container.classList.add('show');
  if (shouldRestorePosition) restorePosition();

  if (companion.mood === 'sleepy') {
    sprite.classList.add('sleeping');
  } else {
    sprite.classList.remove('sleeping');
  }

  clearTimeout(blinkTimeout);
  blinkTimeout = setTimeout(triggerBlink, 3000 + Math.random() * 5000);
}

function startDialogueLoop() {
  clearInterval(dialogueInterval);
  dialogueInterval = setInterval(() => {
    const dialogue = getRandomDialogue();
    if (dialogue) showSpeech(dialogue);
  }, 30000 + Math.random() * 30000);
}

container.addEventListener('click', (e) => {
  if (hasMoved) return;

  const companion = getCompanion();
  if (!companion) return;

  const pokemon = getCompanionPokemon();
  const responses = [
    `${pokemon?.name || '小伙伴'}：你好呀！`,
    `${pokemon?.name || '小伙伴'}：今天天气真好~`,
    `${pokemon?.name || '小伙伴'}：摸摸我嘛~`,
    `${pokemon?.name || '小伙伴'}：想出去玩！`,
    `${pokemon?.name || '小伙伴'}：你在忙什么呢？`,
    `Lv.${companion.level} ${pokemon?.name || ''}：我会一直陪着你的！`,
  ];
  const response = responses[Math.floor(Math.random() * responses.length)];
  showSpeech(response, 4000);

  for (let i = 0; i < 3; i++) {
    setTimeout(createHeartParticle, i * 150);
  }

  sprite.style.animation = 'none';
  sprite.offsetHeight;
  sprite.style.animation = 'floatExcited 0.3s ease-in-out 2';
  setTimeout(() => {
    if (companion.mood === 'sleepy') {
      sprite.style.animation = 'sleepBob 2s ease-in-out infinite';
    } else {
      sprite.style.animation = 'floatBounce 3s ease-in-out infinite';
    }
  }, 600);
});

// Double-click to reset position
container.addEventListener('dblclick', () => {
  localStorage.removeItem(POSITION_KEY);
  container.style.left = '';
  container.style.bottom = '';
  container.style.right = '';
  showSpeech('回到默认位置啦~', 2000);
});

function resetPositionToDefault() {
  localStorage.removeItem(POSITION_KEY);
  container.style.left = '';
  container.style.bottom = '';
  container.style.right = '';
}

ensureCompanion();
// Fallback: if no companion exists (e.g., empty collection), create a default one
if (!getCompanion()) {
  saveCompanion(createDefaultCompanion());
}
let currentCompanionId = getCompanion()?.id || null;
updateSprite(true); // restore position on first load
startDialogueLoop();

window.addEventListener('storage', (e) => {
  if (e.key === COMPANION_KEY) {
    const newId = getCompanion()?.id;
    if (newId !== currentCompanionId) {
      currentCompanionId = newId;
      resetPositionToDefault();
    }
    updateSprite();
  }
});

setInterval(() => {
  const newId = getCompanion()?.id;
  if (newId !== currentCompanionId) {
    currentCompanionId = newId;
    resetPositionToDefault();
  }
  updateSprite();
}, 5000);
</script>
